# ==============================================
# BASE DE DONNÉES (PostgreSQL sur VPS via Coolify)
# ==============================================
# Format : postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Sur Coolify, HOST = nom du service PostgreSQL (ex: postgres)
DATABASE_URL="postgresql://newappai:MotDePasseSecret@postgres:5432/newappai"

# ==============================================
# APPLICATION
# ==============================================
NEXT_PUBLIC_SITE_URL="https://votre-domaine.com"

# Mot de passe admin pour accéder au back-office
ADMIN_PASSWORD="changez-ce-mot-de-passe"

# Secret pour les sessions (min 32 caractères)
SESSION_SECRET="un-secret-tres-long-et-aleatoire-minimum-32-chars"

# ==============================================
# STRIPE (Paiements)
# ==============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==============================================
# IA ASSISTANT (optionnel, un suffit)
# ==============================================
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIza..."
MERMAID_API_KEY=""

# ==============================================
# EMAIL / SMTP (formulaire de contact)
# ==============================================
# Exemple avec OVH : ssl0.ovh.net port 465 (SSL) ou 587 (TLS)
# Exemple avec Gmail : smtp.gmail.com port 587 (utiliser un App Password)
SMTP_HOST="smtp.exemple.com"
SMTP_PORT="587"
SMTP_USER="no-reply@votre-domaine.com"
SMTP_PASS="votre-mot-de-passe-smtp"
# Email de destination des messages de contact
CONTACT_EMAIL="contact@votre-domaine.com"

# ==============================================
# INFORMATIONS SITE (pages légales, emails)
# ==============================================
NEXT_PUBLIC_COMPANY_NAME="NewAppAI"
NEXT_PUBLIC_CONTACT_EMAIL="contact@votre-domaine.com"
NEXT_PUBLIC_COMPANY_ADDRESS="Votre adresse, Ville, Pays"

# ==============================================
# LOGGING
# ==============================================
# Niveaux : trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
